# Django core
SECRET_KEY=change-me-before-production
DEBUG=True

# CORS / CSRF (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
# Use SQLite for local development
DB_ENGINE=django.db.backends.sqlite3
SQLITE_PATH=backend/db.sqlite3

# PostgreSQL example (uncomment when DB_ENGINE is postgresql)
# DB_ENGINE=postgresql
# DB_NAME=cinematch_db
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# Cache
USE_REDIS_CACHE=False
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT=0.1
REDIS_SOCKET_TIMEOUT=0.1

# Security/perf tuning
PBKDF2_PASSWORD_ITERATIONS=300000

